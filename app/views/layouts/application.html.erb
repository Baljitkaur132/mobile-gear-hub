<!DOCTYPE html>
<html lang="en">
  <head>
    <title>Mobile Gear Hub</title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
  </head>
  <body>
    <nav class="navbar navbar-expand-lg navbar-dark bg-dark">
      <div class="container">
        <%= link_to "Mobile Gear Hub", root_path, class: "navbar-brand fw-bold" %>
        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
          <span class="navbar-toggler-icon"></span>
        </button>
        <div class="collapse navbar-collapse" id="navbarNav">
          <ul class="navbar-nav me-auto">
            <li class="nav-item"><%= link_to "Home", root_path, class: "nav-link" %></li>
            <li class="nav-item dropdown">
              <a class="nav-link dropdown-toggle" href="#" data-bs-toggle="dropdown">Categories</a>
              <ul class="dropdown-menu">
                <% Category.all.each do |cat| %>
                  <li><%= link_to cat.name, category_path(cat), class: "dropdown-item" %></li>
                <% end %>
              </ul>
            </li>
            <li class="nav-item"><%= link_to "About", about_path, class: "nav-link" %></li>
            <li class="nav-item"><%= link_to "Contact", contact_path, class: "nav-link" %></li>
          </ul>
          <div class="d-flex align-items-center gap-2">
            <form action="<%= products_path %>" method="get" class="d-flex gap-2">
              <input type="text" name="search" class="form-control form-control-sm" placeholder="Search products..." value="<%= params[:search] %>">
              <select name="category_id" class="form-select form-select-sm" style="width: auto;">
                <option value="">All Categories</option>
                <% Category.all.each do |cat| %>
                  <option value="<%= cat.id %>" <%= 'selected' if params[:category_id].to_s == cat.id.to_s %>><%= cat.name %></option>
                <% end %>
              </select>
              <button type="submit" class="btn btn-outline-light btn-sm">Search</button>
            </form>
            <% if user_signed_in? %>
              <div class="dropdown">
                <button class="btn btn-outline-light btn-sm dropdown-toggle" data-bs-toggle="dropdown">
                  <%= current_user.name %>
                </button>
                <ul class="dropdown-menu dropdown-menu-end">
                  <li><%= link_to "My Orders", orders_path, class: "dropdown-item" %></li>
                  <li><hr class="dropdown-divider"></li>
                  <li><%= link_to "Logout", destroy_user_session_path, data: { turbo_method: :delete }, class: "dropdown-item" %></li>
                </ul>
              </div>
            <% else %>
              <%= link_to "Login", new_user_session_path, class: "btn btn-outline-light btn-sm" %>
              <%= link_to "Sign Up", new_user_registration_path, class: "btn btn-warning btn-sm" %>
            <% end %>
            <%= link_to "Cart (#{session[:cart]&.values&.sum || 0})", cart_path, class: "btn btn-warning btn-sm fw-bold" %>
          </div>
        </div>
      </div>
    </nav>

    <%= render 'shared/flash_messages' %>
    <%= yield %>

    <footer class="bg-dark text-white text-center py-3 mt-5">
      <p class="mb-0">&copy; <%= Time.now.year %> Mobile Gear Hub. All rights reserved.</p>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
  </body>
</html>
