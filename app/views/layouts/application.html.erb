<!DOCTYPE html>
<html lang="en">
  <head>
    <title>Mobile Gear Hub</title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
  </head>
  <body>
    <nav class="navbar navbar-expand-lg navbar-dark bg-dark">
      <div class="container">
        <%= link_to "Mobile Gear Hub", root_path, class: "navbar-brand fw-bold" %>
        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
          <span class="navbar-toggler-icon"></span>
        </button>
        <div class="collapse navbar-collapse" id="navbarNav">
          <ul class="navbar-nav me-auto">
            <li class="nav-item">
              <%= link_to "Home", root_path, class: "nav-link" %>
            </li>
            <li class="nav-item dropdown">
              <a class="nav-link dropdown-toggle" href="#" data-bs-toggle="dropdown">Categories</a>
              <ul class="dropdown-menu">
                <%= link_to "All Products", products_path, class: "dropdown-item" %>
                <li><hr class="dropdown-divider"></li>
                <% Category.all.each do |category| %>
                  <li><%= link_to category.name, category_path(category), class: "dropdown-item" %></li>
                <% end %>
              </ul>
            </li>
          </ul>
          <form class="d-flex me-2" action="<%= products_path %>" method="get">
            <input class="form-control me-2" type="search" name="search" placeholder="Search products..." value="<%= params[:search] %>">
            <select name="category_id" class="form-select me-2">
              <option value="">All Categories</option>
              <% Category.all.each do |cat| %>
                <option value="<%= cat.id %>" <%= 'selected' if params[:category_id].to_s == cat.id.to_s %>><%= cat.name %></option>
              <% end %>
            </select>
            <button class="btn btn-outline-light" type="submit">Search</button>
          </form>
          <ul class="navbar-nav ms-2">
            <%= render "shared/user_nav" %>
            <li class="nav-item ms-2">
              <%= link_to "Cart (#{session[:cart]&.values&.sum || 0})", cart_path, class: "btn btn-warning btn-sm" %>
            </li>
          </ul>
        </div>
      </div>
    </nav>

    <%= render "shared/flash_messages" %>

    <main>
      <%= yield %>
    </main>

    <footer class="bg-dark text-light py-4 mt-5">
      <div class="container text-center">
        <p class="mb-0">&copy; <%= Time.now.year %> Mobile Gear Hub. All rights reserved.</p>
      </div>
    </footer>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
  </body>
</html>
