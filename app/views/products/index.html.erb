<div class="container py-4">
  <div class="d-flex justify-content-between align-items-center mb-4">
    <h1><%= @current_category ? @current_category.name : "All Products" %></h1>
    <div class="btn-group">
      <%= link_to "All", products_path, class: "btn btn-outline-secondary btn-sm" %>
      <%= link_to "On Sale", products_path(filter: "on_sale"), class: "btn btn-outline-danger btn-sm" %>
      <%= link_to "New", products_path(filter: "new"), class: "btn btn-outline-success btn-sm" %>
    </div>
  </div>

  <% if @products.empty? %>
    <div class="alert alert-info">No products found.</div>
  <% else %>
    <div class="row row-cols-1 row-cols-md-3 g-4">
      <% @products.each do |product| %>
        <%= render "product_card", product: product %>
      <% end %>
    </div>
  <% end %>
</div>
