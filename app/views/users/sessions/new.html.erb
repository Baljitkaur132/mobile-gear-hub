<div class="container py-4">
  <div class="row justify-content-center">
    <div class="col-md-5">
      <div class="card shadow">
        <div class="card-header bg-dark text-white">
          <h4 class="mb-0">Login</h4>
        </div>
        <div class="card-body">
          <form action="<%= user_session_path %>" method="post">
            <input type="hidden" name="authenticity_token" value="<%= form_authenticity_token %>">
            <div class="mb-3">
              <label class="form-label">Email</label>
              <input type="email" name="user[email]" class="form-control" required>
            </div>
            <div class="mb-3">
              <label class="form-label">Password</label>
              <input type="password" name="user[password]" class="form-control" required>
            </div>
            <div class="mb-3 form-check">
              <input type="checkbox" name="user[remember_me]" class="form-check-input" id="remember_me">
              <label class="form-check-label" for="remember_me">Remember me</label>
            </div>
            <div class="d-grid">
              <button type="submit" class="btn btn-primary btn-lg">Login</button>
            </div>
          </form>
          <div class="text-center mt-3">
            <%= link_to "Don't have an account? Sign Up", new_user_registration_path %>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>
